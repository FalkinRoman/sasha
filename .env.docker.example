# Скопируй в .env для Docker: cp .env.docker.example .env
# Потом: docker compose up -d --build

APP_NAME=ProstoYoga
APP_ENV=production
APP_KEY=
# После первого cp: docker compose run --rm --no-deps --entrypoint php app artisan key:generate
# Скопируй вывод в APP_KEY=base64:...
APP_DEBUG=false
# Локально: http://localhost   | VPS по IP: http://89.23.101.239  | с доменом: https://...
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=prostoyoga
DB_USERNAME=prostoyoga
DB_PASSWORD=придумай_сложный_пароль

# Пароль root для контейнера MariaDB (обязателен для docker-compose)
DB_ROOT_PASSWORD=другой_сложный_пароль_root

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Порт сайта снаружи (если 80 занят: HTTP_PORT=8080)
HTTP_PORT=80
HTTPS_PORT=443
# default.conf — только HTTP (локалка). На VPS с TLS: production.conf + серты в /etc/letsencrypt
NGINX_CONF_FILE=default.conf
MYSQL_PORT=3306

# Остальное скопируй из .env.example (почта, ЮKassa, Telegram, LESSON_VIDEO_MAX_MB, …)
