# =============================================================================
# PROSTO.YOGA — прод / копирование на сервер
# Скопируй: cp .env.example .env && php artisan key:generate
# =============================================================================

APP_NAME=ProstoYoga
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://твой-домен.ru

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# -----------------------------------------------------------------------------
# База данных — прод: MySQL 8+
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=prostoyoga
DB_USERNAME=prostoyoga
DB_PASSWORD=

# Локально можно оставить sqlite:
# DB_CONNECTION=sqlite
# (и закомментировать DB_* выше; файл database/database.sqlite)

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Воркер очереди на проде обязателен, иначе письма (код верификации и т.д.) не отправятся:
# php artisan queue:work database --sleep=3 --tries=3
# (supervisor / systemd — см. доку Laravel Queues)

CACHE_STORE=database

# Макс. размер видео урока, МБ (Laravel + подстрой nginx client_max_body_size и PHP upload_max_filesize/post_max_size).
# Для больших файлов подними max_execution_time / max_input_time в php-fpm или nginx proxy_read_timeout.
LESSON_VIDEO_MAX_MB=2048

# -----------------------------------------------------------------------------
# Бренд, SEO, превью ссылок (Open Graph)
# APP_URL должен совпадать с публичным URL — иначе og:image будет с неверным доменом.
# -----------------------------------------------------------------------------
PROSTOY_SITE_NAME=PROSTO.YOGA
PROSTOY_META_DESCRIPTION="PROSTO.YOGA — 12 практик онлайн, 3 раза в неделю. За 30 дней: осанка, тело, энергия."
PROSTOY_OG_IMAGE=images/figma/decstop.webp
PROSTOY_OG_IMAGE_WIDTH=1920
PROSTOY_OG_IMAGE_HEIGHT=1080

PROSTOY_CONTACT_EMAIL=prostoyoga@mail.ru

# -----------------------------------------------------------------------------
# Почта (Mail.ru / Sendmail / и т.д.)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mail.ru
MAIL_PORT=465
MAIL_USERNAME=prostoyoga@mail.ru
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=prostoyoga@mail.ru
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Telegram — заявки на оплату (дублируется/перекрывается настройками в админке)
# Админка → Настройки: токен, chat id, галочка «включить».
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFICATIONS_CHAT_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=false

# ЮKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Предпродажа: также переключатель в админке
PRESALE_MANUAL_PAYMENT=true
PRESALE_AUTO_PROMO_CODE=PRESALE20

# -----------------------------------------------------------------------------
# Docker (docker compose) — см. .env.docker.example, DB_HOST=mysql, DB_ROOT_PASSWORD
# Деплой: git pull → docker compose build → docker compose up -d
# Cron на хосте: * * * * * docker compose -f /path/to/project/docker-compose.yml exec -T app php artisan schedule:run
# -----------------------------------------------------------------------------
