APP_NAME=ProstoYoga
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# -----------------------------------------------------------------------------
# Контактный email сайта (футер, страницы, ссылки «написать»)
# -----------------------------------------------------------------------------
PROSTOY_CONTACT_EMAIL=prostoyoga@mail.ru

# -----------------------------------------------------------------------------
# Почта — пример для Mail.ru (smtp.mail.ru)
# Логин SMTP = полный адрес ящика. Включи IMAP/POP3/SMTP в настройках Mail.ru
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mail.ru
MAIL_PORT=465
MAIL_USERNAME=prostoyoga@mail.ru
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=prostoyoga@mail.ru
MAIL_FROM_NAME="${APP_NAME}"

# Альтернатива: порт 587 + MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Telegram: уведомления о новых заявках на оплату (кнопка «Подтвердить заявку» / ЮKassa)
#
# 1) В Telegram открой @BotFather → /newbot → имя и username бота → скопируй HTTP API token
#    → вставь в TELEGRAM_BOT_TOKEN (вид: 123456789:AAH...).
#
# 2) Узнать CHAT_ID получателя (куда слать):
#    - Личные сообщения: напиши боту любое слово, открой в браузере:
#      https://api.telegram.org/bot<ТВОЙ_ТОКЕН>/getUpdates
#      в ответе message.chat.id — твоё user id (число, может быть отрицательным для групп).
#    - Группа: добавь бота в группу, отправь сообщение, снова getUpdates — chat.id вида -100...
#    - Быстро: бот @userinfobot или @getidsbot пришлёт твой user id.
#
# 3) TELEGRAM_NOTIFICATIONS_ENABLED=true — только после того, как токен и chat_id проверены.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_NOTIFICATIONS_CHAT_ID=
TELEGRAM_NOTIFICATIONS_ENABLED=false

# ЮKassa (https://yookassa.ru/)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Предпродажа в UI/ценах: переключатель в админке → Настройки (/admin/settings)
PRESALE_MANUAL_PAYMENT=true
PRESALE_AUTO_PROMO_CODE=PRESALE20
